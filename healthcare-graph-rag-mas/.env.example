APP_ENV=local
DATABASE_URL=postgresql://health:health@localhost:5432/healthrag
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=healthgraph
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
MEM0_ENABLED=false
NEMO_GUARDRAILS_CONFIG=./infra/nemo

# Live researcher-agent retrieval (NIH, CDC, FDA, PubMed). All four APIs are
# free/keyless for light usage; set USE_LIVE_EXTERNAL_APIS=false to force the
# deterministic offline fixtures (useful for fully offline demos/CI).
USE_LIVE_EXTERNAL_APIS=true
EXTERNAL_API_TIMEOUT_SECONDS=10.0
# Optional: raises NCBI (PubMed) and openFDA rate limits if set.
NCBI_API_KEY=
OPENFDA_API_KEY=

