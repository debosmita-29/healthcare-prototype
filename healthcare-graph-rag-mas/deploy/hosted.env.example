# Copy to deploy/hosted.env on your Docker host, replace secrets, then run:
# docker compose --env-file deploy/hosted.env -f docker-compose.hosted.yml up -d --build

APP_NAME=Healthcare Graph RAG MAS
API_PORT=8000

# Database credentials used by the Postgres container and the API DATABASE_URL.
POSTGRES_USER=health
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=healthrag
POSTGRES_BIND_ADDR=127.0.0.1
POSTGRES_PORT=5433

# Neo4j credentials used by the Neo4j container and the API.
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=replace-with-a-long-random-password
NEO4J_HTTP_BIND_ADDR=127.0.0.1
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_BIND_ADDR=127.0.0.1
NEO4J_BOLT_PORT=7687

# Ollama is internal to Compose for API calls. Bind to 127.0.0.1 for admin use
# through SSH tunneling, or change to 0.0.0.0 only behind a firewall/reverse proxy.
OLLAMA_MODEL=llama3.2
OLLAMA_BIND_ADDR=127.0.0.1
OLLAMA_PORT=11434
LLM_TIMEOUT_SECONDS=120

# Phoenix traces are sent internally to http://phoenix:6006.
PHOENIX_BIND_ADDR=127.0.0.1
PHOENIX_PORT=6006

# mem0 uses Qdrant inside Compose at qdrant:6333.
MEM0_ENABLED=true
QDRANT_BIND_ADDR=127.0.0.1
QDRANT_PORT=6333

# Public-source retrieval.
USE_LIVE_EXTERNAL_APIS=true
EXTERNAL_API_TIMEOUT_SECONDS=15
NCBI_API_KEY=
OPENFDA_API_KEY=
